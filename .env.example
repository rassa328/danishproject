# Azure AI Speech — used only by `npm run tts` to pre-generate Danish audio.
# Not needed at build/deploy time (clips are committed under public/audio/).
# Copy to .env (gitignored) and fill in your values.

AZURE_SPEECH_KEY=your-azure-speech-key
AZURE_SPEECH_REGION=westeurope
# Optional. Female default; da-DK-JeppeNeural is the male alternative.
AZURE_SPEECH_VOICE=da-DK-ChristelNeural
