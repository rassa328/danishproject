---
import type { Card } from '../lib/vocab.ts';

interface Props {
  cards: Card[];
}
const { cards } = Astro.props;
---

<table class="vocab">
  <thead>
    <tr>
      <th scope="col" lang="da">Dansk</th>
      <th scope="col">Svenska</th>
      <th scope="col">Not</th>
    </tr>
  </thead>
  <tbody>
    {
      cards.map((c) => (
        <tr>
          <td>
            <span class="da" lang="da" data-audio={c.audio}>{c.danish}</span>
            {c.exampleDa && (
              <div class="ex" lang="da" data-audio={c.audioExample}>{c.exampleDa}</div>
            )}
          </td>
          <td>
            {c.swedish}
            {c.exampleSv && <div class="ex">{c.exampleSv}</div>}
          </td>
          <td class="note">
            {c.tags.includes('falsk-ven') && <span class="warn" title="Falsk vän">⚠ </span>}
            {c.note}
          </td>
        </tr>
      ))
    }
  </tbody>
</table>

<style>
  .vocab {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--step-0);
  }
  .vocab th,
  .vocab td {
    text-align: left;
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--subtle-border);
    vertical-align: top;
  }
  .vocab th {
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    opacity: 0.6;
  }
  .da {
    font-weight: 600;
  }
  .ex {
    font-size: var(--step--1);
    opacity: 0.7;
    margin-top: var(--sp-1);
  }
  .note {
    font-size: var(--step--1);
    opacity: 0.8;
  }
  .warn {
    color: var(--warn);
    opacity: 1;
  }
</style>
