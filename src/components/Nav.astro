---
import { withBase } from '../lib/url.ts';

const path = Astro.url.pathname.replace(/\/$/, '');
const links = [
  { href: withBase(''), label: 'Hem' },
  { href: withBase('lektioner'), label: 'Lektioner' },
  { href: withBase('flashcards'), label: 'Flashcards' },
  { href: withBase('ordlista'), label: 'Ordlista' },
];
const isActive = (href: string) => path === href.replace(/\/$/, '');
---

<nav aria-label="Huvudmeny">
  <a class="brand" href={withBase('')}><span lang="da">Dansk</span> för svenskar</a>
  <ul>
    {
      links.map((l) => (
        <li>
          <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-4);
    max-width: var(--maxw);
    margin-inline: auto;
    padding: var(--sp-4);
    border-bottom: 1px solid var(--border);
  }
  .brand {
    font-weight: 700;
    text-decoration: none;
    color: var(--text);
    margin-right: auto;
  }
  .brand [lang='da'] { color: var(--accent); }
  ul {
    display: flex;
    gap: var(--sp-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  a[aria-current='page'] {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
