---
import { withBase } from '../lib/url.ts';
import { UI } from '../lib/strings.ts';

const path = Astro.url.pathname.replace(/\/$/, '');
const links = [
  { href: withBase(''), label: UI.nav.home, match: 'exact' as const },
  { href: withBase('lektioner'), label: UI.nav.lessons, match: 'prefix' as const },
  { href: withBase('flashcards'), label: UI.nav.flashcards, match: 'prefix' as const },
  { href: withBase('ordlista'), label: UI.nav.wordlist, match: 'prefix' as const },
];
const norm = (href: string) => href.replace(/\/$/, '');
const isActive = (l: (typeof links)[number]) =>
  l.match === 'exact' ? path === norm(l.href) : path === norm(l.href) || path.startsWith(norm(l.href) + '/');
---

<nav aria-label={UI.nav.menuLabel}>
  <a class="brand" href={withBase('')}><span lang="da">{UI.brandDa}</span>{UI.brandRest}</a>
  <ul>
    {
      links.map((l) => (
        <li>
          <a href={l.href} aria-current={isActive(l) ? 'page' : undefined}>
            {l.label}
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--sp-4);
    max-width: var(--maxw);
    margin-inline: auto;
    padding: var(--sp-4);
    border-bottom: 1px solid var(--border);
  }
  .brand {
    font-weight: 700;
    text-decoration: none;
    color: var(--text);
    margin-right: auto;
  }
  .brand [lang='da'] { color: var(--accent); }
  ul {
    display: flex;
    gap: var(--sp-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  a[aria-current='page'] {
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
</style>
