---
import { withBase } from '../lib/url.ts';
import { UI } from '../lib/strings.ts';

const path = Astro.url.pathname.replace(/\/$/, '');
// Redesign nav: the wordmark is the home link (no separate "Hem"), "Tal" is
// removed from the nav (the /tal route still exists), and Zen renders as the
// "◎ Zen" text mark that always reads as ink and hovers red.
const links = [
  { href: withBase('lektioner'), label: UI.nav.lessons },
  { href: withBase('flashcards'), label: UI.nav.flashcards },
  { href: withBase('ordlista'), label: UI.nav.wordlist },
];
const norm = (href: string) => href.replace(/\/$/, '');
const isActive = (href: string) => {
  const n = norm(href);
  return path === n || path.startsWith(n + '/');
};
const zenHref = withBase('zen');
---

<nav aria-label={UI.nav.menuLabel}>
  <a class="brand" href={withBase('')}
    ><span lang="da">{UI.brandDa}</span><span class="brand-rest">{UI.brandRest}</span></a
  >
  <div class="links">
    {
      links.map((l) => (
        <a href={l.href} aria-current={isActive(l.href) ? 'page' : undefined}>
          {l.label}
        </a>
      ))
    }
    <a
      class="zen"
      href={zenHref}
      title={UI.nav.zenLabel}
      aria-current={isActive(zenHref) ? 'page' : undefined}
    >
      <span aria-hidden="true">◎</span> {UI.nav.zen}
    </a>
    <button type="button" data-theme-toggle="true" aria-label={UI.themeToggle} title={UI.themeToggle}
      >◐</button
    >
  </div>
</nav>

<style>
  nav {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px 24px;
    max-width: var(--content-w);
    width: 100%;
    margin: 0 auto;
    padding: 24px clamp(18px, 5vw, 40px);
    box-sizing: border-box;
  }
  .brand {
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink);
  }
  .brand [lang='da'] {
    color: var(--red);
  }
  .brand-rest {
    font-weight: 400;
  }
  .links {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    /* 12px column floor: at 320px the row has 284px; a 14px floor overflows by
       1px and wraps the theme toggle onto its own line. */
    gap: 12px clamp(12px, 3.5vw, 26px);
    font-size: 13.5px;
  }
  .links a {
    text-decoration: none;
    color: var(--mut2);
    transition: color 120ms ease;
    /* Touch hit area ~42px tall; negative margin keeps the layout footprint
       (4px sides stay inside the 12px column gap, so neighbors don't overlap). */
    padding: 10px 4px;
    margin: -10px -4px;
  }
  .links a:hover,
  .links a:focus-visible {
    color: var(--ink);
  }
  /* Current page reads as ink and weightier. */
  .links a[aria-current='page'] {
    color: var(--ink);
    font-weight: 500;
  }
  /* Zen is always ink 500 and hovers red — the one link that stands apart. */
  .links a.zen {
    color: var(--ink);
    font-weight: 500;
  }
  .links a.zen:hover,
  .links a.zen:focus-visible {
    color: var(--red);
  }
  .links button[data-theme-toggle] {
    font: inherit;
    font-size: 14px;
    line-height: 1;
    color: var(--mut4);
    background: none;
    border: none;
    cursor: pointer;
    /* The bare ◐ glyph is a 13x14px box — padding grows the touch target to
       ~40px while the negative margin keeps the visual footprint unchanged. */
    padding: 13px;
    margin: -13px;
    align-self: center;
    transition: color 120ms ease;
  }
  .links button[data-theme-toggle]:hover,
  .links button[data-theme-toggle]:focus-visible {
    color: var(--ink);
  }
</style>
