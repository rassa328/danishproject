---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import SiteHead from '../components/SiteHead.astro';
import { withBase } from '../lib/url.ts';
import { UI } from '../lib/strings.ts';
import { cardCount } from '../lib/decks.ts';
import { praksisUniqueCount } from '../lib/praksis.ts';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
// Total studyable words, deduped (starter ∪ praksis) — the footer's ordlista
// count, shown site-wide.
const totalWords = (cardCount + praksisUniqueCount).toLocaleString('sv-SE');
---

<!doctype html>
<html lang="sv" data-theme="dark">
  <head>
    <SiteHead title={title} description={description} />
  </head>
  <body>
    <a class="skip-link" href="#main">{UI.skipLink}</a>
    <div class="site-shell">
      <Nav />
      <main id="main"><slot /></main>
      <footer>
        <span>{UI.footerAudio}</span>
        <span aria-hidden="true">·</span>
        <span>{UI.footerProgress}</span>
        <span aria-hidden="true">·</span>
        <a href={withBase('ordlista')}>{UI.footerWordlist(totalWords)}</a>
      </footer>
    </div>
    <style>
      .site-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        background: var(--bg);
      }
      /* Override the global `main` defaults: pages own their content width. */
      main {
        max-width: none;
        width: 100%;
        margin: 0;
        padding: 0;
        flex: 1;
        display: flex;
        flex-direction: column;
      }
      footer {
        display: flex;
        align-items: baseline;
        justify-content: center;
        flex-wrap: wrap;
        gap: 8px 22px;
        padding: 96px 24px 44px;
        font-size: 12.5px;
        color: var(--mut3);
        text-align: center;
      }
      footer a {
        color: var(--mut3);
        text-decoration: none;
        transition: color 120ms ease;
      }
      footer a:hover,
      footer a:focus-visible {
        color: var(--ink);
      }
      /* When the footer wraps to stacked lines, the '·' separators dangle at
         line ends — hide them; stacked lines need no separators. */
      @media (max-width: 640px) {
        footer > span[aria-hidden] {
          display: none;
        }
      }
    </style>
  </body>
</html>
