---
// Chrome-less shell for full-viewport take-over pages (/zen): the same head as
// BaseLayout but no nav, skip-link or footer — the island owns the screen and
// renders its own ◐ theme toggle (top-right). Background follows the shared
// data-theme tokens (dark default) so there is no flash before hydration.
import '../styles/global.css';
import SiteHead from '../components/SiteHead.astro';

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="sv" data-theme="dark">
  <head>
    <SiteHead title={title} description={description} />
  </head>
  <body>
    <main id="main">
      <slot />
    </main>
    <style>
      main {
        max-width: none;
        padding: 0;
        margin: 0;
        min-height: 100vh;
      }
    </style>
  </body>
</html>
