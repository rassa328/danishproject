---
import BaseLayout from './BaseLayout.astro';
import { withBase } from '../lib/url.ts';
import { formatLevel } from '../lib/format.ts';
import { UI } from '../lib/strings.ts';
import LessonAudio from '../components/LessonAudio.svelte';
import LessonProgress from '../components/LessonProgress.svelte';
import Checkpoint from '../components/Checkpoint.svelte';
import lessonAudio from '../data/lesson-audio.json';

type LessonRef = { id: string; title: string };
type CheckpointQ = { q: string; options: string[]; answer: number };
interface Props {
  lessonId: string;
  title: string;
  level: 'b1' | 'b2';
  topic: string;
  estMinutes: number;
  summary: string;
  objectives?: string[];
  prerequisites?: LessonRef[];
  vocabTags: string[];
  checkpoint?: CheckpointQ[];
  prev?: LessonRef | null;
  next?: LessonRef | null;
  position?: string;
}
const {
  lessonId,
  title,
  level,
  topic,
  estMinutes,
  summary,
  objectives = [],
  prerequisites = [],
  vocabTags,
  checkpoint = [],
  prev = null,
  next = null,
  position,
} = Astro.props;
const practiceHref = vocabTags.length
  ? withBase(`flashcards?tag=${encodeURIComponent(vocabTags[0]!)}&from=${encodeURIComponent(lessonId)}`)
  : null;
const topicLabel: Record<string, string> = {
  pronunciation: 'Uttal',
  'false-friends': 'Falska vänner',
  numbers: 'Tal',
  spelling: 'Stavning',
  listening: 'Lyssnarförståelse',
  grammar: 'Grammatik',
  idiom: 'Idiom',
  vocabulary: 'Ordförråd',
};
---

<BaseLayout title={title} description={summary}>
  <p class="back"><a href={withBase('lektioner')}>{UI.lessons.backToList}</a>{position && <span class="pos"> · {UI.lessons.positionPrefix} {position}</span>}</p>
  <header class="lesson-head">
    <h1>{title}</h1>
    <p class="meta">
      <span class="badge">{formatLevel(level)}</span>
      <span>{topicLabel[topic] ?? topic}</span>
      <span>· {estMinutes} min</span>
      <LessonProgress client:idle lessonId={lessonId} />
    </p>
    {
      prerequisites.length > 0 && (
        <p class="prereq">
          {UI.lessons.prerequisitesLabel}{' '}
          {prerequisites.map((p, i) => (
            <>
              {i > 0 && ', '}
              <a href={withBase(`lektioner/${p.id}`)}>{p.title}</a>
            </>
          ))}
        </p>
      )
    }
    {
      objectives.length > 0 && (
        <div class="objectives">
          <p class="objectives-head">{UI.lessons.objectivesHead}</p>
          <ul>{objectives.map((o) => <li>{o}</li>)}</ul>
        </div>
      )
    }
  </header>

  <article class="prose">
    <slot />
  </article>
  <div id="lesson-end" aria-hidden="true"></div>

  <LessonAudio clips={lessonAudio} client:idle />

  {checkpoint.length > 0 && <Checkpoint client:visible items={checkpoint} />}

  {
    practiceHref && (
      <div class="practice">
        <a class="cta" href={practiceHref}>{UI.lessons.practiceCta}</a>
        {vocabTags.length > 1 && (
          <p class="vocab-link">
            {UI.lessons.trainWords}{' '}
            {vocabTags.map((t) => (
              <a class="chip" href={withBase(`flashcards?tag=${encodeURIComponent(t)}`)}>
                #{t}
              </a>
            ))}
          </p>
        )}
      </div>
    )
  }

  {
    (prev || next) && (
      <nav class="lesson-nav" aria-label={UI.lessons.navLabel}>
        {prev ? (
          <a class="nav-prev" href={withBase(`lektioner/${prev.id}`)}>
            <span class="dir">{UI.lessons.prev}</span>
            <span class="nav-title">{prev.title}</span>
          </a>
        ) : (
          <span />
        )}
        {next && (
          <a class="nav-next" href={withBase(`lektioner/${next.id}`)}>
            <span class="dir">{UI.lessons.next}</span>
            <span class="nav-title">{next.title}</span>
          </a>
        )}
      </nav>
    )
  }

  <style>
    .back { font-size: var(--step--1); margin: 0 0 var(--sp-2); }
    .pos { color: var(--muted); }
    .lesson-head { margin-bottom: var(--sp-6); }
    .prereq { font-size: var(--step--1); color: var(--muted); margin: var(--sp-2) 0 0; }
    .objectives { margin-top: var(--sp-4); padding: var(--sp-3) var(--sp-4); border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); }
    .objectives-head { margin: 0 0 var(--sp-1); font-weight: 600; font-size: var(--step--1); }
    .objectives ul { margin: 0; padding-left: 1.2em; }
    .objectives li { font-size: var(--step--1); }
    .lesson-nav { display: flex; justify-content: space-between; gap: var(--sp-3); margin-top: var(--sp-8); }
    .lesson-nav a { flex: 1 1 0; display: flex; flex-direction: column; gap: var(--sp-1); padding: var(--sp-3) var(--sp-4); border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); text-decoration: none; color: inherit; }
    .lesson-nav a:hover { border-color: var(--accent); }
    .lesson-nav .nav-next { text-align: right; }
    .lesson-nav .dir { font-size: var(--step--1); color: var(--muted); }
    .lesson-nav .nav-title { font-weight: 600; }
    .meta { display: flex; flex-wrap: wrap; gap: var(--sp-2); align-items: center; color: var(--muted); font-size: var(--step--1); margin: 0; }
    .badge { background: var(--accent); color: var(--accent-contrast); border-radius: var(--radius-pill); padding: 0 var(--sp-2); font-weight: 600; font-size: 0.75rem; }
    .prose :global(h2) { border-bottom: 1px solid var(--border); padding-bottom: var(--sp-1); }
    .prose :global(table) { width: 100%; border-collapse: collapse; font-size: var(--step--1); margin: var(--sp-4) 0; }
    .prose :global(th), .prose :global(td) { border: 1px solid var(--border); padding: var(--sp-2); text-align: left; vertical-align: top; }
    .prose :global(blockquote) { margin: var(--sp-4) 0; padding: var(--sp-2) var(--sp-4); border-left: 4px solid var(--warn); background: var(--warn-bg); border-radius: 0 var(--radius) var(--radius) 0; }
    .prose :global(code) { background: var(--code-bg); padding: 0.1em 0.3em; border-radius: 4px; }
    /* Click-to-hear: Danish words/sentences become tappable (added by LessonAudio). */
    .prose :global(.da-clickable) { cursor: pointer; text-decoration: underline dotted; text-underline-offset: 0.2em; text-decoration-color: var(--muted); border-radius: 3px; }
    @media (prefers-reduced-motion: no-preference) { .prose :global(.da-clickable) { transition: background-color 0.15s; } }
    .prose :global(.da-clickable:hover), .prose :global(.da-clickable:focus-visible) { text-decoration-color: var(--accent); background: color-mix(in oklab, var(--accent) 12%, transparent); }
    .prose :global(.da-clickable:focus-visible) { outline: 2px solid var(--accent); outline-offset: 2px; }
    .prose :global(.da-clickable.is-playing) { background: color-mix(in oklab, var(--accent) 24%, transparent); }
    .practice { margin-top: var(--sp-8); }
    .cta { display: inline-block; padding: var(--sp-3) var(--sp-6); background: var(--accent); color: var(--accent-contrast); border-radius: var(--radius); text-decoration: none; font-weight: 600; min-height: var(--min-tap); }
    .cta:hover { filter: brightness(1.08); }
    .vocab-link { margin-top: var(--sp-3); margin-bottom: 0; color: var(--muted); font-size: var(--step--1); }
    .chip { display: inline-block; margin: 0 var(--sp-1); padding: 0 var(--sp-2); border: 1px solid var(--border); border-radius: var(--radius-pill); text-decoration: none; font-size: var(--step--1); }
  </style>
</BaseLayout>
