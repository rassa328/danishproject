---
import LessonLayout from '../../layouts/LessonLayout.astro';
import { getCollection, render } from 'astro:content';
import { getNeighbors } from '../../lib/lessons.ts';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);
  const titleById = new Map(lessons.map((l) => [l.id, l.data.title]));
  const link = (l: { id: string; data: { title: string } } | null) =>
    l ? { id: l.id, title: l.data.title } : null;
  return lessons.map((entry) => {
    const { prev, next, index, total } = getNeighbors(lessons, entry.id);
    const prerequisites = entry.data.prerequisites
      .filter((id) => titleById.has(id))
      .map((id) => ({ id, title: titleById.get(id) as string }));
    return {
      params: { id: entry.id },
      props: {
        entry,
        prev: link(prev),
        next: link(next),
        position: String(index + 1) + ' / ' + String(total),
        prerequisites,
      },
    };
  });
}

const { entry, prev, next, position, prerequisites } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<LessonLayout
  lessonId={entry.id}
  title={data.title}
  level={data.level}
  topic={data.topic}
  estMinutes={data.estMinutes}
  summary={data.summary}
  objectives={data.objectives}
  prerequisites={prerequisites}
  vocabTags={data.vocabTags}
  practiceDirection={data.practiceDirection}
  checkpoint={data.checkpoint}
  prev={prev}
  next={next}
  position={position}
>
  <Content />
</LessonLayout>
