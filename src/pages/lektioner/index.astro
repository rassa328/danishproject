---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url.ts';
import { groupByUnit } from '../../lib/lessons.ts';
import { UI } from '../../lib/strings.ts';
import LessonsProgress from '../../components/LessonsProgress.svelte';

const lessons = await getCollection('lessons', ({ data }) => !data.draft);
const units = groupByUnit(lessons);
const lessonIds = lessons.map((l) => l.id);
---

<BaseLayout title={UI.nav.lessons} description="Korta danska lektioner för svenskar: uttal, falska vänner och tal.">
  <div class="page">
    <header class="ghost-head">
      <span class="ghost" aria-hidden="true">Æ Ø Å</span>
      <h1>{UI.nav.lessons}</h1>
      <p class="lead">{UI.lessons.indexLead}</p>
    </header>
    <LessonsProgress client:idle ids={lessonIds} />

    {
      units.map((u) => (
        <section class="unit">
          <h2>{u.label}</h2>
          <p class="unit-blurb">{u.blurb}</p>
          <div class="lessons">
            {u.lessons.map((l) => (
              <a class="lesson-row" href={withBase(`lektioner/${l.id}`)}>
                <span class="text">
                  <span class="title">{l.data.title}</span>
                  <span class="desc">{l.data.summary}</span>
                </span>
                <span class="min">{l.data.estMinutes} min</span>
              </a>
            ))}
          </div>
        </section>
      ))
    }
  </div>

  <style>
    .page {
      flex: 1;
      width: min(720px, 92vw);
      margin: 0 auto;
      padding: 48px 0 0;
      position: relative;
    }
    .ghost-head {
      padding: 8px 0 4px;
    }
    .page h1 {
      position: relative;
      margin: 0;
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: 46px;
      letter-spacing: -0.02em;
      line-height: 1.1;
      color: var(--ink);
    }
    .lead {
      position: relative;
      margin: 12px 0 0;
      font-size: 15px;
      color: var(--mut1);
    }

    .unit {
      margin-top: 56px;
    }
    .unit h2 {
      margin: 0 0 4px;
      font-family: var(--font-serif);
      font-weight: 600;
      font-size: 23px;
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: var(--ink);
    }
    .unit-blurb {
      margin: 0 0 8px;
      font-size: 13.5px;
      color: var(--mut3);
    }
    .lessons {
      display: flex;
      flex-direction: column;
    }
    .lesson-row {
      display: flex;
      align-items: baseline;
      gap: 18px;
      padding: 17px 6px;
      border-bottom: 1px solid var(--bd2);
      text-decoration: none;
      color: inherit;
      transition: background-color 120ms ease;
    }
    .lesson-row:hover,
    .lesson-row:focus-visible {
      background: var(--card);
    }
    .text {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 3px;
    }
    .title {
      font-size: 15.5px;
      font-weight: 500;
      color: var(--ink);
    }
    .desc {
      font-size: 13px;
      line-height: 1.5;
      color: var(--mut2);
    }
    .min {
      flex: none;
      font-size: 12.5px;
      color: var(--mut3);
    }
  </style>
</BaseLayout>
