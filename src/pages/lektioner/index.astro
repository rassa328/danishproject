---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url.ts';

const lessons = (await getCollection('lessons', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Lektioner" description="Korta danska lektioner för svenskar: uttal, falska vänner och tal.">
  <h1>Lektioner</h1>
  <p class="lead">Korta lektioner om det som faktiskt är svårt för svenskar.</p>

  <ul class="lessons">
    {
      lessons.map((l) => (
        <li>
          <a href={withBase(`lektioner/${l.id}`)}>
            <span class="row">
              <span class="badge">{l.data.level.toUpperCase()}</span>
              <strong>{l.data.title}</strong>
              <span class="min">{l.data.estMinutes} min</span>
            </span>
            <span class="summary">{l.data.summary}</span>
          </a>
        </li>
      ))
    }
  </ul>

  <style>
    .lead { color: var(--muted); }
    .lessons { list-style: none; padding: 0; display: grid; gap: var(--sp-3); }
    .lessons a { display: block; padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); text-decoration: none; color: inherit; }
    .lessons a:hover { border-color: var(--accent); }
    .row { display: flex; align-items: center; gap: var(--sp-3); }
    .badge { background: var(--accent); color: var(--accent-contrast); border-radius: var(--radius-pill); padding: 0 var(--sp-2); font-weight: 600; font-size: 0.75rem; }
    .min { margin-left: auto; color: var(--muted); font-size: var(--step--1); }
    .summary { display: block; margin-top: var(--sp-2); color: var(--muted); font-size: var(--step--1); }
  </style>
</BaseLayout>
