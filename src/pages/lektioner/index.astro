---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { withBase } from '../../lib/url.ts';
import { groupByUnit } from '../../lib/lessons.ts';
import { formatLevel } from '../../lib/format.ts';
import { UI } from '../../lib/strings.ts';
import LessonsProgress from '../../components/LessonsProgress.svelte';

const lessons = await getCollection('lessons', ({ data }) => !data.draft);
const units = groupByUnit(lessons);
const lessonIds = lessons.map((l) => l.id);
---

<BaseLayout title={UI.nav.lessons} description="Korta danska lektioner för svenskar: uttal, falska vänner och tal.">
  <header class="ghost-head">
    <span class="ghost" aria-hidden="true">Æ Ø Å</span>
    <h1>{UI.nav.lessons}</h1>
    <p class="lead">{UI.lessons.indexLead}</p>
  </header>
  <LessonsProgress client:idle ids={lessonIds} />

  {
    units.map((u) => (
      <section class="unit">
        <h2>{u.label}</h2>
        <p class="unit-blurb">{u.blurb}</p>
        <ul class="lessons">
          {u.lessons.map((l) => (
            <li>
              <a href={withBase(`lektioner/${l.id}`)}>
                <span class="row">
                  <span class="badge">{formatLevel(l.data.level)}</span>
                  <strong>{l.data.title}</strong>
                  <span class="min">{l.data.estMinutes} min</span>
                </span>
                <span class="summary">{l.data.summary}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }

  <style>
    .lead { color: var(--muted); }
    .unit { margin-top: var(--sp-8); }
    .unit h2 { margin-bottom: var(--sp-1); }
    .unit-blurb { color: var(--muted); font-size: var(--step--1); margin: 0 0 var(--sp-4); }
    .lessons { list-style: none; padding: 0; display: grid; gap: var(--sp-3); }
    .lessons a { display: block; padding: var(--sp-4); border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); text-decoration: none; color: inherit; }
    .lessons a:hover { border-color: var(--accent); }
    .row { display: flex; align-items: center; gap: var(--sp-3); }
    .badge { background: var(--accent); color: var(--accent-contrast); border-radius: var(--radius-pill); padding: 0 var(--sp-2); font-weight: 600; font-size: 0.75rem; }
    .min { margin-left: auto; color: var(--muted); font-size: var(--step--1); }
    .summary { display: block; margin-top: var(--sp-2); color: var(--muted); font-size: var(--step--1); }
  </style>
</BaseLayout>
