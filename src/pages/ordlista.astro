---
import BaseLayout from '../layouts/BaseLayout.astro';
import VocabTable from '../components/VocabTable.astro';
import WordAudio from '../components/WordAudio.svelte';
import OrdlistaSearch from '../components/OrdlistaSearch.svelte';
import { withBase } from '../lib/url.ts';
import { allCards, cardCount } from '../lib/decks.ts';
import { praksisUniqueCount } from '../lib/praksis.ts';
import { formatLevel } from '../lib/format.ts';
import { themeKey, themeLabel } from '../lib/deck-groups.ts';
import { UI } from '../lib/strings.ts';
import type { Card } from '../lib/vocab.ts';

// Group every card by theme (themeKey/themeLabel shared with the reviewer).
const groups = new Map<string, Card[]>();
for (const c of allCards) {
  const k = themeKey(c.deck);
  const arr = groups.get(k);
  if (arr) arr.push(c);
  else groups.set(k, [c]);
}

// Biggest themes first; within a theme, words sorted by Danish (da collation).
// `key` doubles as the reviewer group id suffix (starter:<key>) for the
// "Träna →" link on each section header — deck-groups owns both sides.
const sections = [...groups.entries()]
  .map(([key, cards]) => ({
    key,
    label: themeLabel(key),
    levels: [...new Set(cards.map((c) => c.cefr))].sort(),
    cards: [...cards].sort((a, b) => a.danish.localeCompare(b.danish, 'da')),
  }))
  .sort((a, b) => b.cards.length - a.cards.length || a.label.localeCompare(b.label, 'sv'));

// The search island covers starter ∪ praksis; praksis arrives via the lazy
// JSON fetch, so only these slim starter entries ride along as props.
const searchStarter = allCards.map((c) => ({
  id: c.id,
  danish: c.danish,
  swedish: c.swedish,
  deck: c.deck,
  ...(c.audio ? { audio: c.audio } : {}),
}));
const totalWords = cardCount + praksisUniqueCount;
---

<BaseLayout title={UI.wordlist.title} description={UI.wordlist.description(totalWords)}>
  <header class="ghost-head">
    <span class="ghost" aria-hidden="true">Æ Ø Å</span>
    <h1>{UI.wordlist.title}</h1>
    <p class="lead">{UI.wordlist.lead(cardCount, totalWords)}</p>
  </header>

  <OrdlistaSearch client:idle starter={searchStarter} />

  {
    sections.map((s) => (
      <section class="theme">
        <h2>
          {s.label}
          <span class="meta">{s.levels.map((l) => formatLevel(l)).join(' · ')} · {s.cards.length} ord</span>
          <a
            class="train"
            href={withBase(`flashcards?group=${encodeURIComponent(`starter:${s.key}`)}`)}
            title={UI.wordlist.trainThemeTitle(s.label)}
          >
            {UI.wordlist.trainTheme}
          </a>
        </h2>
        <VocabTable cards={s.cards} />
      </section>
    ))
  }

  <WordAudio client:idle />

  <style>
    .lead { color: var(--muted); }
    .theme { margin-top: var(--sp-8); }
    .theme h2 {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: var(--sp-3);
      border-bottom: 1px solid var(--border);
      padding-bottom: var(--sp-1);
    }
    .theme h2 .meta {
      font-size: var(--step--1);
      font-weight: 400;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .theme h2 .train {
      margin-left: auto;
      font-size: var(--step--1);
      font-weight: 600;
      white-space: nowrap;
    }

    /* Click-to-hear affordance (class added at runtime by WordAudio). */
    :global(.da-clickable) {
      cursor: pointer;
      text-decoration: underline dotted;
      text-underline-offset: 0.2em;
      text-decoration-color: var(--muted);
      border-radius: 3px;
    }
    @media (prefers-reduced-motion: no-preference) {
      :global(.da-clickable) { transition: background-color 0.15s; }
    }
    :global(.da-clickable:hover),
    :global(.da-clickable:focus-visible) {
      text-decoration-color: var(--accent);
      background: color-mix(in oklab, var(--accent) 12%, transparent);
    }
    :global(.da-clickable:focus-visible) { outline: 2px solid var(--accent); outline-offset: 2px; }
    :global(.da-clickable.is-playing) { background: color-mix(in oklab, var(--accent) 24%, transparent); }

    /* Printable cheat sheet: drop the chrome and the click affordance. */
    @media print {
      :global(nav), :global(footer), :global(.skip-link) { display: none !important; }
      .theme h2 .train { display: none; }
      :global(.da-clickable) { text-decoration: none; cursor: auto; background: none; }
      .theme { break-inside: avoid; }
    }
  </style>
</BaseLayout>
