---
import BaseLayout from '../layouts/BaseLayout.astro';
import VocabTable from '../components/VocabTable.astro';
import WordAudio from '../components/WordAudio.svelte';
import OrdlistaSearch from '../components/OrdlistaSearch.svelte';
import { withBase } from '../lib/url.ts';
import { allCards, cardCount } from '../lib/decks.ts';
import { praksisUniqueCount } from '../lib/praksis.ts';
import { themeKey, themeLabel } from '../lib/deck-groups.ts';
import { UI } from '../lib/strings.ts';
import type { Card } from '../lib/vocab.ts';

// Group every card by theme (themeKey/themeLabel shared with the reviewer).
const groups = new Map<string, Card[]>();
for (const c of allCards) {
  const k = themeKey(c.deck);
  const arr = groups.get(k);
  if (arr) arr.push(c);
  else groups.set(k, [c]);
}

// Biggest themes first; within a theme, words sorted by Danish (da collation).
// `key` doubles as the reviewer group id suffix (starter:<key>) for the
// "Träna →" link on each section header — deck-groups owns both sides.
const sections = [...groups.entries()]
  .map(([key, cards]) => ({
    key,
    label: themeLabel(key),
    cards: [...cards].sort((a, b) => a.danish.localeCompare(b.danish, 'da')),
  }))
  .sort((a, b) => b.cards.length - a.cards.length || a.label.localeCompare(b.label, 'sv'));

// The search island covers starter ∪ praksis; praksis arrives via the lazy
// JSON fetch, so only these slim starter entries ride along as props.
const searchStarter = allCards.map((c) => ({
  id: c.id,
  danish: c.danish,
  swedish: c.swedish,
  deck: c.deck,
  tags: c.tags,
  ...(c.audio ? { audio: c.audio } : {}),
  ...(c.exampleDa ? { exampleDa: c.exampleDa } : {}),
  ...(c.exampleSv ? { exampleSv: c.exampleSv } : {}),
  ...(c.audioExample ? { audioExample: c.audioExample } : {}),
  ...(c.note ? { note: c.note } : {}),
}));
const totalWords = cardCount + praksisUniqueCount;
---

<BaseLayout title={UI.wordlist.title} description={UI.wordlist.description(totalWords)}>
  <div class="page">
    <header class="ghost-head">
      <span class="ghost" aria-hidden="true">Æ Ø Å</span>
      <h1>{UI.wordlist.title}</h1>
      <p class="lead">{UI.wordlist.lead(totalWords)}</p>
    </header>

    <OrdlistaSearch client:idle starter={searchStarter} />

    <div id="ordlista-sections">
    {
      sections.map((s) => (
        <section class="theme">
          <div class="theme-head">
            <div class="theme-title">
              <h2>{s.label}</h2>
              <span class="count">{s.cards.length} ORD</span>
            </div>
            <a
              class="train"
              href={withBase(`flashcards?group=${encodeURIComponent(`starter:${s.key}`)}`)}
              title={UI.wordlist.trainThemeTitle(s.label)}
            >
              {UI.wordlist.trainTheme}
            </a>
          </div>
          <VocabTable cards={s.cards} />
        </section>
      ))
    }

      <p class="list-note">visar de {cardCount} utvalda grundorden</p>
    </div>

    <WordAudio client:idle />
  </div>

  <style>
    .page {
      flex: 1;
      width: min(760px, 92vw);
      margin: 0 auto;
      padding: 48px 0 0;
      position: relative;
    }
    .ghost-head {
      padding: 8px 0 4px;
    }
    .page h1 {
      position: relative;
      margin: 0;
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: 46px;
      letter-spacing: -0.02em;
      line-height: 1.1;
      color: var(--ink);
    }
    .lead {
      position: relative;
      margin: 12px 0 0;
      font-size: 15px;
      color: var(--mut1);
    }

    .theme {
      margin-top: 0;
    }
    .theme-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 16px;
      margin-top: 44px;
    }
    .theme-title {
      display: flex;
      align-items: baseline;
      gap: 14px;
    }
    .theme-title h2 {
      margin: 0;
      font-family: var(--font-serif);
      font-weight: 600;
      font-size: 23px;
      letter-spacing: -0.01em;
      line-height: 1.2;
      color: var(--ink);
    }
    .count {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--mut3);
      white-space: nowrap;
    }
    .train {
      flex: none;
      font-size: 13px;
      color: var(--mut1);
      text-decoration: none;
      white-space: nowrap;
      transition: color 120ms ease;
    }
    .train:hover,
    .train:focus-visible {
      color: var(--red);
    }

    .list-note {
      margin: 28px 2px 0;
      font-size: 12.5px;
      color: var(--mut3);
    }

    /* Click-to-hear affordance (class added at runtime by WordAudio on
       [data-audio] spans — the Danish word + example). */
    :global(.da-clickable) {
      cursor: pointer;
      text-decoration: underline dotted;
      text-underline-offset: 0.2em;
      text-decoration-color: var(--mut5);
      border-radius: 3px;
      transition: color 120ms ease;
    }
    @media (prefers-reduced-motion: no-preference) {
      :global(.da-clickable) {
        transition:
          color 120ms ease,
          background-color 0.15s;
      }
    }
    :global(.da-clickable:hover),
    :global(.da-clickable:focus-visible) {
      color: var(--red);
      text-decoration-color: var(--red);
    }
    :global(.da-clickable:focus-visible) {
      outline: 2px solid var(--red);
      outline-offset: 2px;
    }
    :global(.da-clickable.is-playing) {
      color: var(--red);
      background: color-mix(in oklab, var(--red) 14%, transparent);
    }
    /* Only the head word carries the always-on dotted underline; example
       sentences stay plain (still playable — the affordance shows on hover). */
    :global(.ex.da-clickable) {
      text-decoration-line: none;
    }
    :global(.ex.da-clickable:hover),
    :global(.ex.da-clickable:focus-visible) {
      text-decoration-line: underline;
    }

    /* Printable cheat sheet: drop the chrome and the click affordance. */
    @media print {
      :global(nav),
      :global(footer),
      :global(.skip-link) {
        display: none !important;
      }
      .train {
        display: none;
      }
      :global(.da-clickable) {
        text-decoration: none;
        cursor: auto;
        background: none;
      }
      .theme {
        break-inside: avoid;
      }
    }
  </style>
</BaseLayout>
