---
import { withBase } from '../lib/url.ts';
---

<html lang="sv">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Lär dig danska som svensktalande (B1–B2): uttal, falska vänner, tal och lyssnarförståelse." />
		<title>Dansk för svenskar</title>
	</head>
	<body>
		<main>
			<p class="kicker">Dansk for svenskere</p>
			<h1>Lär dig <span lang="da">dansk</span> — på riktigt</h1>
			<p class="lead">
				Du läser redan danska. Det svåra är att <strong>höra</strong> och
				<strong>uttala</strong> det: stød, blødt d, det vigesimala talsystemet,
				falska vänner och talad danska.
			</p>
			<p class="soon">🚧 Bygget pågår — flashcards och lektioner kommer snart.</p>
		</main>
		<style>
			:root { color-scheme: light dark; }
			body {
				margin: 0;
				min-height: 100dvh;
				display: grid;
				place-items: center;
				font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
				line-height: 1.5;
				background: Canvas;
				color: CanvasText;
			}
			main { max-width: 36rem; padding: 2rem; }
			.kicker { text-transform: uppercase; letter-spacing: .08em; font-size: .8rem; opacity: .6; margin: 0 0 .5rem; }
			h1 { font-size: clamp(2rem, 6vw, 3rem); margin: 0 0 1rem; }
			h1 span[lang="da"] { color: #c8102e; }
			.lead { font-size: 1.15rem; opacity: .9; }
			.soon { margin-top: 2rem; font-size: .95rem; opacity: .7; }
		</style>
	</body>
</html>
