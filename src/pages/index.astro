---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url.ts';
import { allCards, cardCount } from '../lib/decks.ts';
import { praksisCount } from '../lib/praksis.ts';
import { UI } from '../lib/strings.ts';
import ProgressSummary from '../components/ProgressSummary.svelte';
import DailyMission from '../components/DailyMission.svelte';
import InputLog from '../components/InputLog.svelte';

// Curated headwords the daily mission can weave in (small payload).
const missionPool = allCards.map((c) => c.danish);
// startedCount() spans starter ∪ praksis (both are studyable), so the progress
// denominator must too — else it can read "N av 187" with N > 187.
const totalWords = cardCount + praksisCount;
---

<BaseLayout
  title="Dansk för svenskar"
  description="Lär dig danska som svensktalande (B1–B2): uttal, falska vänner, tal och lyssnarförståelse."
>
  <p class="kicker">Dansk for svenskere</p>
  <h1>Lär dig <span lang="da">dansk</span> — på riktigt</h1>
  <p class="lead">
    Du läser redan danska. Det svåra är att <strong>höra</strong> och
    <strong>uttala</strong> det: stød, blødt d, det vigesimala talsystemet,
    falska vänner och talad danska. Den här sidan tränar just det.
  </p>

  <p class="path-hint">{UI.progress.homeHint}</p>
  <ProgressSummary client:idle total={totalWords} />

  <div class="cards">
    <a class="card" href={withBase('lektioner')}>
      <span class="step">1</span>
      <h2>Lektioner</h2>
      <p>Korta lektioner om stød, falska vänner och det vigesimala talsystemet.</p>
    </a>
    <a class="card" href={withBase('flashcards')}>
      <span class="step">2</span>
      <h2>Flashcards</h2>
      <p>Skriv det danska ordet utifrån svenskan. {cardCount} kort som repeteras precis innan du glömmer dem.</p>
    </a>
    <a class="card" href={withBase('ordlista')}>
      <span class="step">3</span>
      <h2>Ordlista</h2>
      <p>Alla {cardCount} ord med svensk översättning, exempel och uttal — din referenslista.</p>
    </a>
  </div>

  <section class="practice">
    <h2>{UI.practice.heading}</h2>
    <p class="practice-intro">{UI.practice.intro}</p>
    <div class="practice-grid">
      <DailyMission client:idle pool={missionPool} />
      <InputLog client:idle />
    </div>
  </section>

  <style>
    .kicker { text-transform: uppercase; letter-spacing: 0.08em; font-size: var(--step--1); color: var(--muted); margin: 0 0 var(--sp-2); }
    h1 span[lang='da'] { color: var(--accent); }
    .lead { font-size: var(--step-1); color: var(--muted); }
    .path-hint { margin: var(--sp-6) 0 0; font-weight: 600; }
    .cards { display: grid; gap: var(--sp-4); grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr)); margin-top: var(--sp-4); }
    .card { position: relative; display: block; padding: var(--sp-4) var(--sp-6); border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface); text-decoration: none; color: inherit; }
    .card:hover { border-color: var(--accent); }
    .card .step { position: absolute; top: var(--sp-4); right: var(--sp-4); width: 1.5em; height: 1.5em; display: grid; place-items: center; border-radius: var(--radius-pill); background: var(--accent); color: var(--accent-contrast); font-size: var(--step--1); font-weight: 700; }
    .card h2 { margin: 0 0 var(--sp-2); color: var(--accent); }
    .card p { margin: 0; color: var(--muted); font-size: var(--step--1); }
    .practice { margin-top: var(--sp-8); }
    .practice > h2 { margin: 0 0 var(--sp-1); }
    .practice-intro { color: var(--muted); margin: 0 0 var(--sp-4); }
    .practice-grid { display: grid; gap: var(--sp-4); grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); align-items: start; }
  </style>
</BaseLayout>
