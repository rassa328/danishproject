---
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../lib/url.ts';
import { cardCount } from '../lib/decks.ts';
import { praksisUniqueCount } from '../lib/praksis.ts';
import StodCard from '../components/StodCard.svelte';

// Total studyable words, deduped (starter ∪ praksis). Formatted sv-SE so the
// thousands separator is a space ("5 077"), matching the design.
const totalWords = (cardCount + praksisUniqueCount).toLocaleString('sv-SE');
---

<BaseLayout
  title="Dansk för svenskar"
  description="Lär dig förstå talad danska som svensktalande: uttal, stød, falska vänner och lyssnarförståelse."
>
  <div class="home">
    <div class="ghost" aria-hidden="true">Æ Ø Å</div>

    <h1 class="hero-title">Förstå danskar när de <em>faktiskt</em> pratar.</h1>

    <div class="cards">
      {/* Zen card — the practice demonstrates itself; no description. */}
      <a class="card zen-card" href={withBase('zen')}>
        <span class="eyebrow">◎ Zen</span>
        <span class="zen-body">
          <span class="zen-word" lang="da">morsomt</span>
          <span class="zen-rule"></span>
        </span>
      </a>

      {/* Flashcards card — cue → answer + spaced-repetition timeline. */}
      <a class="card fc-card" href={withBase('flashcards')}>
        <span class="fc-head">
          <span class="eyebrow">Flashcards</span>
          <span class="stat">{totalWords} ORD</span>
        </span>
        <span class="fc-body">
          <span class="cue">roligt</span>
          <span class="answer">
            <span class="answer-word" lang="da">morsomt</span>
            <span class="glyph" aria-hidden="true">
              <span style="height:7px"></span>
              <span style="height:15px"></span>
              <span style="height:21px"></span>
              <span style="height:12px"></span>
              <span style="height:7px"></span>
            </span>
          </span>
        </span>
        <span class="fc-foot">
          <span class="timeline" aria-hidden="true" title="spaced repetition">
            <span class="dot"></span>
            <span class="link" style="width:10px"></span>
            <span class="dot"></span>
            <span class="link" style="width:22px"></span>
            <span class="dot"></span>
            <span class="link" style="width:44px"></span>
            <span class="dot"></span>
            <span class="link" style="width:80px"></span>
            <span class="dot dot-empty"></span>
          </span>
          <span class="fc-caption">spaced repetition — varje ord återkommer precis innan du glömmer det</span>
        </span>
      </a>

      {/* Stød card — playable hun/hund waveform (real audio), spans both columns. */}
      <StodCard client:idle lessonHref={withBase('lektioner/01-stoed')} />
    </div>
  </div>

  <style>
    .home {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 72px 24px 0;
      position: relative;
      overflow: hidden;
    }

    .ghost {
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      font-weight: 700;
      font-size: clamp(160px, 26vw, 300px);
      line-height: 1;
      letter-spacing: 0.04em;
      color: var(--ghost);
      white-space: nowrap;
      pointer-events: none;
      user-select: none;
    }

    .hero-title {
      position: relative;
      margin: 0;
      max-width: 860px;
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: clamp(44px, 6.4vw, 78px);
      line-height: 1.04;
      letter-spacing: -0.022em;
      text-wrap: balance;
      color: var(--ink);
    }
    .hero-title em {
      font-style: italic;
      font-weight: 500;
    }

    .cards {
      position: relative;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 18px;
      width: min(880px, 94vw);
      margin-top: 64px;
      text-align: left;
    }

    .card {
      display: flex;
      flex-direction: column;
      min-height: 236px;
      background: var(--card);
      border: 1px solid var(--bd1);
      border-radius: 20px;
      padding: 24px 28px;
      text-decoration: none;
      color: var(--ink);
      box-shadow:
        0 1px 2px var(--sh1),
        0 16px 40px var(--sh2);
      transition: border-color 120ms ease;
    }
    .card:hover,
    .card:focus-visible {
      border-color: var(--mut5);
    }

    .eyebrow {
      font-size: 13.5px;
      font-weight: 600;
      color: var(--ink);
    }

    /* Zen card */
    .zen-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 20px;
    }
    .zen-word {
      font-size: 31px;
      font-weight: 300;
      color: var(--soft);
      letter-spacing: 0.01em;
    }
    .zen-rule {
      width: 168px;
      height: 1px;
      background: var(--bd3);
    }

    /* Flashcards card */
    .fc-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
    }
    .stat {
      font-family: var(--font-mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      color: var(--mut3);
    }
    .fc-body {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }
    .cue {
      font-size: 13.5px;
      color: var(--mut3);
    }
    .answer {
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .answer-word {
      font-family: var(--font-serif);
      font-size: 30px;
      font-weight: 600;
      color: var(--ink);
      letter-spacing: -0.01em;
    }
    .glyph {
      display: flex;
      align-items: center;
      gap: 2.5px;
    }
    .glyph span {
      flex: none;
      width: 3px;
      border-radius: 2px;
      background: var(--red);
    }
    .fc-foot {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 9px;
    }
    .timeline {
      display: flex;
      align-items: center;
    }
    .timeline .dot {
      flex: none;
      width: 5px;
      height: 5px;
      border-radius: 999px;
      background: var(--red);
    }
    .timeline .dot-empty {
      background: transparent;
      border: 1px solid var(--red);
      box-sizing: border-box;
    }
    .timeline .link {
      flex: none;
      height: 1px;
      background: var(--bd3);
    }
    .fc-caption {
      text-align: center;
      font-size: 12.5px;
      color: var(--mut3);
    }
  </style>
</BaseLayout>
